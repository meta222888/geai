#include <windows.h>

#ifndef GEAI_VERSION
#define GEAI_VERSION L"v1.0.0"
#endif

IDI_APP_ICON ICON "@GEAI_ICON_FILE@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Geai"
            VALUE "FileDescription", "Geai Gemini Windows Client"
            VALUE "FileVersion", "1.0.0"
            VALUE "InternalName", "Geai"
            VALUE "OriginalFilename", "Geai.exe"
            VALUE "ProductName", "Geai"
            VALUE "ProductVersion", "1.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END

101 DIALOGEX 0, 0, 260, 150
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Geai Settings"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Gemini API Key", -1, 8, 12, 80, 12
    EDITTEXT 2001, 92, 10, 158, 14, ES_AUTOHSCROLL
    LTEXT "API Base", -1, 8, 38, 80, 12
    EDITTEXT 2002, 92, 36, 158, 14, ES_AUTOHSCROLL
    LTEXT "Model", -1, 8, 64, 80, 12
    EDITTEXT 2003, 92, 62, 158, 14, ES_AUTOHSCROLL
    LTEXT "Proxy", -1, 8, 90, 80, 12
    EDITTEXT 2004, 92, 88, 158, 14, ES_AUTOHSCROLL
    DEFPUSHBUTTON "OK", IDOK, 92, 122, 70, 18
    PUSHBUTTON "Cancel", IDCANCEL, 180, 122, 70, 18
END
